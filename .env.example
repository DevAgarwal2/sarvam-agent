# =============================================
# Hermes Instance 1 — Environment Configuration
# Copy to .env and fill in your keys
# =============================================

# ---- LLM Provider (Chat) ----
# Sarvam AI API key — sign up at https://sarvam.ai
SARVAM_API_KEY=sk_your_sarvam_api_key_here

# ---- Mistral AI (Vision) ----
MISTRAL_API_KEY=your_mistral_api_key_here

# ---- Telegram ----
TELEGRAM_BOT_TOKEN=12345:your_bot_token_here
TELEGRAM_ALLOWED_USERS=your_telegram_user_id
TELEGRAM_HOME_CHANNEL=your_telegram_user_id

# ---- Optional Tools ----
# FAL_KEY=                  # Image generation
# BROWSERBASE_API_KEY=      # Cloud browser
# EXA_API_KEY=              # Web search
# GITHUB_TOKEN=             # GitHub integration
